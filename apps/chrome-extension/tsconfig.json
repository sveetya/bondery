{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["chrome", "node"],
    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"],
      "~": ["./src"],
      "~/*": ["./src/*"],
      "@@": ["."],
      "@@/*": ["./*"],
      "~~": ["."],
      "~~/*": ["./*"],
      "@bondery/helpers": ["../../packages/helpers/src/index.ts"],
      "@bondery/helpers/*": ["../../packages/helpers/src/*"],
      "@bondery/branding": ["../../packages/branding/src/index.ts"],
      "@bondery/mantine-next": ["../../packages/mantine-next/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".output"]
}
